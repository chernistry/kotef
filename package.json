{
    "name": "kotef",
    "version": "0.1.0",
    "description": "Autonomous AI coding & research agent",
    "type": "module",
    "main": "dist/src/index.js",
    "bin": {
        "kotef": "bin/kotef"
    },
    "scripts": {
        "build": "rm -rf dist && tsc && mkdir -p dist/src/agent && cp -r src/agent/prompts dist/src/agent/ && mkdir -p dist/src/tools && cp -r src/tools/grammars dist/src/tools/",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "npm run build && vitest run test/e2e.test.ts",
        "eval": "tsx test/eval/harness.ts",
        "lint": "eslint src test --ext .ts",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "eval:prompts": "npm run build && tsx scripts/eval_prompts.ts"
    },
    "keywords": [
        "ai",
        "agent",
        "coding",
        "llm"
    ],
    "author": "Sasha",
    "license": "Apache-2.0",
    "dependencies": {
        "@langchain/core": "^1.1.31",
        "@langchain/langgraph": "^1.2.1",
        "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "chalk": "^5.3.0",
        "cheerio": "^1.1.2",
        "commander": "^12.0.0",
        "detect-package-manager": "^3.0.2",
        "diff": "^8.0.2",
        "diff-match-patch": "^1.0.5",
        "dotenv": "^16.4.5",
        "execa": "^9.6.0",
        "fast-glob": "^3.3.3",
        "jsonrepair": "^3.13.1",
        "markdown-it": "^14.1.0",
        "npm-run-path": "^6.0.0",
        "openai": "^6.27.0",
        "robots-parser": "^3.0.1",
        "tree-sitter-wasms": "^0.1.13",
        "web-tree-sitter": "^0.26.6",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/diff": "^7.0.2",
        "@types/node": "^25.3.5",
        "@typescript-eslint/eslint-plugin": "^8.47.0",
        "@typescript-eslint/parser": "^8.47.0",
        "eslint": "^8.57.0",
        "prettier": "^3.2.5",
        "ts-morph": "^27.0.2",
        "tsx": "^4.7.1",
        "typescript": "^5.9.3",
        "typescript-language-server": "^5.1.3",
        "vitest": "^4.0.13"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
